# ─── Database ────────────────────────────────────────────────────────────────
# Get the POOLED connection string from Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Solana / Helius ─────────────────────────────────────────────────────────
SOLANA_CLUSTER="devnet"
# Canonical RPC var read by chain-reader, identity, and the permissionless
# drivers (was mis-documented as SOLANA_RPC_URL — nothing reads that).
RPC_URL="https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"
# Optional WS endpoint for the auto-claim driver's send-and-confirm. Defaults to
# RPC_URL with the scheme swapped to wss:// when unset.
# RPC_WS_URL="wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"
HELIUS_API_KEY="your-helius-key"

# Deployed program ID (Phase 2).
PROGRAM_ID="3YpkUKBh8288XN2dCKSwBnEdyc5UozSJ19A1ZCLpUZsZ"

# Optional: filter token transfers by USDC mint when deriving payouts. Devnet
# USDC = 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU. Leave unset to skip filter.
# USDC_MINT=""

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated CORS origins. * is fine for dev; lock down before prod.
FRONTEND_ORIGIN="http://localhost:3000,https://bracketchain.vercel.app"

# ─── Webhook security ────────────────────────────────────────────────────────
# Shared secret for HMAC-SHA256 verification of Helius webhook payloads.
# Generate with: openssl rand -hex 32
# Set the same value in the Helius dashboard (Webhook → Authentication header
# or Signing secret). Requests without a valid X-Helius-Signature (or
# Authorization) header are rejected with 401.
HELIUS_WEBHOOK_SECRET=""

# ─── Phase 1 signing keypairs (@solana/keychain) ─────────────────────────────
# Memory backend (devnet/dev): per-role base58 secret keys. Generate with
# solana-keygen + base58-encode the 64-byte secret. NEVER commit real values.
# Roles map to permissionless crons: sas-issuer (V1.1), claim-payer
# (claim_result/oracle), vrf-payer (reveal_seed), refund-payer
# (partial_refund_chunk), cleanup-payer (close_tournament).
# Prod: set KEYCHAIN_BACKEND="aws-kms" (or turnkey/privy) — zero cron code change.
KEYCHAIN_BACKEND="memory"
KEYCHAIN_SAS_ISSUER=""
KEYCHAIN_CLAIM_PAYER=""
KEYCHAIN_VRF_PAYER=""
KEYCHAIN_REFUND_PAYER=""
KEYCHAIN_CLEANUP_PAYER=""

# ─── Permissionless cron drivers (Phase 1) ───────────────────────────────────
# Master kill switch for ALL signing crons. Default-off: a deploy never signs
# until this is "true". Each driver also needs its own flag below.
PERMISSIONLESS_DRIVERS_ENABLED="false"
# Per-driver flags (land with their crons in Stages B/D/E):
# PERMISSIONLESS_AUTO_CLAIM_ENABLED="false"      # claim_result (V1 player-reported)
# PERMISSIONLESS_VRF_REVEAL_ENABLED="false"      # reveal_seed (V1 player-reported)
# PERMISSIONLESS_PARTIAL_REFUND_ENABLED="false"  # partial_refund_chunk (partial-cancel)
# PERMISSIONLESS_CLOSE_TERMINAL_ENABLED="false"  # close_tournament (program-improvements)

# ─── Identity / SAS attestation issuance (V1.1 A-9 / A-11) ───────────────────
# A-11 (Option B): the indexer owns the full Steam OpenID round-trip, so there
# is no public attest endpoint and no enable-flag — issuance is only reachable
# via the verified /identity/steam/callback path (no IDENTITY_ATTEST_ENABLED).
# SAS Credential + per-game Schema PDAs (devnet defaults from §2 bootstrap).
SAS_CREDENTIAL="A6aCesF4nLNRGBRfUS5dCw9e1f1peGmNhZU4t139Qwjc"
SAS_SCHEMA_DOTA2="4TT2a5ycymMRwZJoGTPfaggb7CtGrDtCXKheF7zeV27m"

# ─── Steam OpenID login (A-11, keyless) ──────────────────────────────────────
# Realm shown to the user + the indexer's OWN callback URL (openid.return_to).
# STEAM_RETURN_URL must point at this indexer's /identity/steam/callback.
STEAM_REALM="http://localhost:3000"
STEAM_RETURN_URL="http://localhost:3000/identity/steam/callback"

# ─── Steam / Dota 2 data (server-side secrets — NEVER NEXT_PUBLIC) ────────────
# Steam Web API key (steamcommunity.com/dev/apikey). NOT needed for Steam OpenID
# login (that's keyless) — consumed by the V1.2 Oracle (GetMatchHistory) and any
# server-side profile lookups. First real use: V1.2.
STEAM_WEB_API_KEY=""
# OpenDota key — Oracle cross-check source for Dota 2 (V1.2). Optional (OpenDota
# has a free no-key tier); a key raises rate limits.
OPENDOTA_API_KEY=""
