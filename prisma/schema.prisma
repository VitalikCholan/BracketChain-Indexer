generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tournament {
  address              String           @id
  organizer            String
  name                 String
  tokenMint            String
  entryFee             BigInt
  organizerDeposit     BigInt           @default(0)
  maxParticipants      Int
  payoutPreset         PayoutPreset
  registrationDeadline DateTime
  status               TournamentStatus
  settlementMode       SettlementMode?
  game                 Game?
  champion             String?
  grossPool            BigInt?
  feeAmount            BigInt?
  netPool              BigInt?
  createdAt            DateTime         @default(now())
  completedAt          DateTime?
  createdTxSig         String
  completedTxSig       String?
  chainSlotAtWrite     BigInt           @default(0)
  arbitrator           String?
  payouts              Payout[]
  participants         Participant[]
  matches              Match[]

  @@index([status])
  @@index([organizer])
}

model Participant {
  id                String     @id @default(uuid())
  tournamentAddress String
  tournament        Tournament @relation(fields: [tournamentAddress], references: [address], onDelete: Cascade)
  wallet            String
  seedIndex         Int
  refundPaid        Boolean    @default(false)
  registeredAt      DateTime   @default(now())
  registeredTxSig   String
  chainSlotAtWrite  BigInt     @default(0)
  wins              Int        @default(0)
  losses            Int        @default(0)
  pointsFor         Int        @default(0)
  pointsAgainst     Int        @default(0)
  identityHash      String?

  @@unique([tournamentAddress, wallet])
  @@index([tournamentAddress])
  @@index([wallet])
}

model Match {
  id                String      @id @default(uuid())
  tournamentAddress String
  tournament        Tournament  @relation(fields: [tournamentAddress], references: [address], onDelete: Cascade)
  bracket           Int         @default(0)
  round             Int
  matchIndex        Int
  playerA           String?
  playerB           String?
  winner            String?
  status            MatchStatus @default(Pending)
  bye               Boolean     @default(false)
  reportedAt        DateTime?
  reportedTxSig     String?
  chainSlotAtWrite  BigInt      @default(0)
  proposalSource    ProposalSource @default(None)
  proposer          String?
  proposedWinner    String?
  proposedAt        DateTime?
  claimDeadline     DateTime?
  disputed          Boolean     @default(false)
  disputeReason     Int?
  lobbyId           Bytes?
  playerAGameId     Bytes?
  playerBGameId     Bytes?
  expectedFeedHash  Bytes?
  committedAt       DateTime?
  switchboardFeed   String?

  @@unique([tournamentAddress, bracket, round, matchIndex])
  @@index([tournamentAddress])
}

enum MatchStatus {
  Pending
  Active
  PendingConfirmation
  Disputed
  Completed
}

enum ProposalSource {
  None
  Player
  Oracle
  GameServer
}

model Payout {
  id                String     @id @default(uuid())
  tournamentAddress String
  tournament        Tournament @relation(fields: [tournamentAddress], references: [address], onDelete: Cascade)
  recipient         String
  amount            BigInt
  kind              PayoutKind
  placement         Int?
  txSignature       String
  createdAt         DateTime   @default(now())
.
  @@unique([txSignature, recipient, kind])
  @@index([tournamentAddress])
}

enum PayoutPreset {
  WinnerTakesAll
  Standard
  Deep
}

enum TournamentStatus {
  Registration
  PendingBracketInit
  Active
  Completed
  Cancelled
  PartialCancelled
}

enum SettlementMode {
  OrganizerOnly
  PlayerReported
  Oracle
}

enum Game {
  Manual
  Dota2
  Cs2Faceit
  Valorant
  LoL
}

model SteamIdentity {
  identityHash String   @id
  steamId64    String
  wallet       String
  linkedAt     DateTime @default(now())

  @@index([wallet])
}

enum PayoutKind {
  Prize
  Refund
  Fee
  OrganizerRefund
}
